<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Landing Page</title>
    <style>
        :root {
            --bg: linear-gradient(135deg, #0b1224, #1f273f);
            --card: rgba(255, 255, 255, 0.08);
            --text: #f7fafc;
            --muted: #c0c8d7;
            --accent: #6c63ff;
            --accent-soft: rgba(108, 99, 255, 0.18);
            --shadow: 0 30px 80px rgba(0, 0, 0, 0.25);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            min-height: 100%;
            background: var(--bg);
            color: var(--text);
            font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }

        body {
            line-height: 1.6;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px 20px;
        }

        .container {
            width: min(1120px, 100%);
            display: grid;
            gap: 36px;
            grid-template-columns: 1.2fr 0.8fr;
        }

        .hero {
            padding: 42px 48px;
            border-radius: 32px;
            background: rgba(255, 255, 255, 0.06);
            backdrop-filter: blur(18px);
            box-shadow: var(--shadow);
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: -10%;
            right: -20%;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            background: var(--accent-soft);
            filter: blur(40px);
            opacity: 0.85;
        }

        .hero-content {
            position: relative;
            z-index: 1;
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--accent);
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-bottom: 22px;
            font-size: 0.85rem;
        }

        .eyebrow::before {
            content: '';
            width: 32px;
            height: 1px;
            background: currentColor;
        }

        .hero h1 {
            font-size: clamp(2.8rem, 5vw, 4.4rem);
            margin-bottom: 18px;
            max-width: 12ch;
        }

        .hero p {
            color: var(--muted);
            max-width: 44rem;
            margin-bottom: 28px;
        }

        .button-row {
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
        }

        .button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 16px 26px;
            border-radius: 999px;
            font-weight: 700;
            text-decoration: none;
            transition: transform 0.24s ease, box-shadow 0.24s ease;
        }

        .button.primary {
            background: linear-gradient(135deg, #6c63ff, #9c88ff);
            color: white;
            box-shadow: 0 18px 40px rgba(108, 99, 255, 0.35);
        }

        .button.secondary {
            border: 1px solid rgba(255, 255, 255, 0.16);
            color: var(--text);
            background: rgba(255, 255, 255, 0.04);
        }

        .button:hover {
            transform: translateY(-1px);
        }

        .card {
            padding: 32px;
            border-radius: 28px;
            background: var(--card);
            box-shadow: var(--shadow);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .card h2 {
            margin-bottom: 22px;
            font-size: 1.6rem;
        }

        .contact-details {
            display: grid;
            gap: 18px;
            margin-bottom: 28px;
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 18px 20px;
            border-radius: 22px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.06);
        }

        .contact-icon {
            width: 42px;
            height: 42px;
            display: grid;
            place-items: center;
            border-radius: 14px;
            background: rgba(108, 99, 255, 0.12);
            color: white;
            font-size: 1.15rem;
        }

        .contact-text {
            display: grid;
            gap: 4px;
        }

        .contact-text strong {
            font-weight: 700;
        }

        .contact-text span {
            color: var(--muted);
            font-size: 0.975rem;
        }

        .social-list {
            display: grid;
            gap: 12px;
        }

        .social-link {
            display: inline-flex;
            align-items: center;
            gap: 14px;
            padding: 16px 20px;
            border-radius: 18px;
            color: var(--text);
            background: rgba(255, 255, 255, 0.05);
            text-decoration: none;
            border: 1px solid rgba(255, 255, 255, 0.08);
            transition: transform 0.18s ease, background 0.18s ease;
        }

        .social-link:hover {
            transform: translateY(-1px);
            background: rgba(255, 255, 255, 0.09);
        }

        .footer-note {
            color: var(--muted);
            font-size: 0.95rem;
            margin-top: 16px;
        }

        .map-panel {
            margin-top: 26px;
            border-radius: 24px;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .map-panel img {
            width: 100%;
            display: block;
            min-height: 220px;
            object-fit: cover;
        }

        @media (max-width: 900px) {
            .container {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 620px) {
            body {
                padding: 28px 16px;
            }
            .hero {
                padding: 28px 22px;
            }
            .card {
                padding: 26px;
            }
            .button-row {
                flex-direction: column;
                align-items: stretch;
            }
        }
    </style>
</head>
<body>
    <main class="container">
        <section class="hero">
            <div class="hero-content">
                <span class="eyebrow">Let’s connect</span>
                <h1>Contact Me</h1>
                <p>Fast, friendly, and easy to reach. I’m here for collaborations, project opportunities, and quick questions — let’s make something great together.</p>
                <div class="button-row">
                    <a class="button primary" href="mailto:your.email@example.com">Email Me</a>
                    <a class="button secondary" href="#details">View Details</a>
                </div>
            </div>
        </section>

        <aside class="card" id="details">
            <h2>Contact details</h2>
            <div class="contact-details">
                <article class="contact-item">
                    <div class="contact-icon">✉️</div>
                    <div class="contact-text">
                        <strong>Email</strong>
                        <span>your.email@example.com</span>
                    </div>
                </article>
                <article class="contact-item">
                    <div class="contact-icon">📞</div>
                    <div class="contact-text">
                        <strong>Phone</strong>
                        <span>+1 (555) 123-4567</span>
                    </div>
                </article>
                <article class="contact-item">
                    <div class="contact-icon">📍</div>
                    <div class="contact-text">
                        <strong>Location</strong>
                        <span>San Francisco, CA</span>
                    </div>
                </article>
            </div>

            <div class="social-list">
                <a class="social-link" href="https://www.linkedin.com/" target="_blank" rel="noreferrer noopener">
                    <span>LinkedIn</span>
                    <strong>@your-profile</strong>
                </a>
                <a class="social-link" href="https://github.com/" target="_blank" rel="noreferrer noopener">
                    <span>GitHub</span>
                    <strong>@your-handle</strong>
                </a>
                <a class="social-link" href="https://twitter.com/" target="_blank" rel="noreferrer noopener">
                    <span>Twitter</span>
                    <strong>@yourhandle</strong>
                </a>
            </div>

            <div class="footer-note">Tip: Replace the placeholders with your real contact details and social links to personalize this landing page.</div>

            <div class="map-panel">
                <img src="https://images.unsplash.com/photo-1524548165309-06a13a7b8ce5?auto=format&fit=crop&w=1200&q=80" alt="City skyline and office map illustration">
            </div>
        </aside>
    </main>
</body>
</html>